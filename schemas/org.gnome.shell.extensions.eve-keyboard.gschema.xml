<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.eve-keyboard"
          path="/org/gnome/shell/extensions/eve-keyboard/">
    <key name="theme" type="s">
      <default>'dark'</default>
      <summary>Keyboard theme</summary>
      <description>'dark' or 'light'</description>
    </key>
    <key name="key-size" type="s">
      <default>'M'</default>
      <summary>Key size</summary>
      <description>'S', 'M', or 'L'</description>
    </key>
    <key name="layout" type="s">
      <default>'us'</default>
      <summary>Keyboard layout</summary>
      <description>'auto', 'us', or 'br'</description>
    </key>
    <key name="layout-mode" type="i">
      <default>0</default>
      <summary>Keyboard layout mode</summary>
      <description>0=full, 1=tenkeyless, 2=75percent, 3=minimal</description>
    </key>
    <key name="opacity" type="d">
      <default>1.0</default>
      <summary>Keyboard opacity</summary>
      <description>1.0=opaque, 0.75, 0.50, 0.25</description>
    </key>
    <key name="auto-show" type="b">
      <default>true</default>
      <summary>Auto-show when focusing text input</summary>
    </key>
    <key name="sticky-modifiers" type="b">
      <default>true</default>
      <summary>Sticky modifiers (release after 1 key)</summary>
    </key>
    <key name="panel-x" type="i">
      <default>-1</default>
      <summary>Panel X position (-1 = centered)</summary>
    </key>
    <key name="panel-y" type="i">
      <default>-1</default>
      <summary>Panel Y position (-1 = bottom center)</summary>
    </key>
    <key name="monitor-index" type="i">
        <default>0</default>
        <summary>Index of the monitor where the keyboard appears</summary>
    </key>
    <key name="panel-scale" type="d">
        <default>1.0</default>
        <summary>Keyboard scale (1.0 = 100%, 0.8 = 80%, 1.2 = 120%)</summary>
    </key>
  </schema>
</schemalist>