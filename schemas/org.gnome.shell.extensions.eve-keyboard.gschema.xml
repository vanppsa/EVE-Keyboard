<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.eve-keyboard"
          path="/org/gnome/shell/extensions/eve-keyboard/">
    <key name="theme" type="s">
      <default>'dark'</default>
      <summary>Tema do teclado</summary>
      <description>'dark' ou 'light'</description>
    </key>
    <key name="key-size" type="s">
      <default>'M'</default>
      <summary>Tamanho das teclas</summary>
      <description>'S', 'M' ou 'L'</description>
    </key>
    <key name="layout" type="s">
      <default>'auto'</default>
      <summary>Layout do teclado</summary>
      <description>'auto', 'us' ou 'br'</description>
    </key>
    <key name="auto-show" type="b">
      <default>true</default>
      <summary>Mostrar automaticamente ao focar campo de texto</summary>
    </key>
    <key name="sticky-modifiers" type="b">
      <default>true</default>
      <summary>Modificadores sticky (soltam após 1 tecla)</summary>
    </key>
    <key name="panel-x" type="i">
      <default>-1</default>
      <summary>Posição X do painel (-1 = centralizado)</summary>
    </key>
    <key name="panel-y" type="i">
      <default>-1</default>
      <summary>Posição Y do painel (-1 = bottom center)</summary>
    </key>
    <key name="monitor-index" type="i">
      <default>0</default>
      <summary>Índice do monitor onde o teclado aparece</summary>
    </key>
  </schema>
</schemalist>
